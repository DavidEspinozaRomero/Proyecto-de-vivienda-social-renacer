---
let {
  OGTitle = "Proyecto de Vivienda Social Renacer | Terrenos en Ambato",
  OGDescription = "¿No tienes casa propia en Ambato? Conoce el proyecto de vivienda social Renacer y descubre cómo obtener tu primer terreno. Información y requisitos disponibles.",
  OGImage = "https://proyectoviviendarenacer.netlify.app/img/mockImg.webp",
} = Astro.props;
---
<!-- Facebook Meta Tags -->
<meta property="og:title" content={OGTitle}>
<meta property="og:description" content={OGDescription}>
<meta property="og:type" content="website">
<meta property="og:url" content="https://proyectoviviendarenacer.netlify.app">
<meta property="og:image" content={OGImage}>

<meta property="og:locale" content="es_EC">
<meta property="og:site_name" content="Proyecto de Vivienda Social Renacer">

<!-- Twitter Card (también usado por WhatsApp) -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Obtén tu primer terreno en Ambato | Proyecto Renacer">
<meta name="twitter:description" content="Proyecto de vivienda social para personas que no tienen propiedad. Conoce requisitos y cómo ser socio del proyecto Renacer.">
<meta name="twitter:image" content="https://proyectoviviendarenacer.netlify.app/img/mockImg.webp">


<meta property="twitter:domain" content="proyectoviviendarenacer.netlify.app/" />
<meta property="twitter:url" content="https://proyectoviviendarenacer.netlify.app" />
<meta name="twitter:site" content="@DEERHOU" />
<meta name="twitter:creator" content="@DEERHOU" />
