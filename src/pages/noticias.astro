---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <div
    class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden"
  >
    <div class="layout-container flex h-full grow flex-col">
      <!-- Top Navigation Bar -->
      <Header />
      <main class="flex-1 px-6 md:px-20 py-12 max-w-7xl mx-auto w-full">
        <!-- Hero Section -->
        <div class="mb-16">
          <h1
            class="text-slate-900 dark:text-slate-100 text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4"
          >
            Noticias y Avances del Proyecto de Vivienda Social Renacer en Ambato
          </h1>
          <div class="flex items-center gap-2 text-primary font-semibold">
            <span class="material-symbols-outlined">verified</span>
            <p class="text-lg">Transparencia y trabajo constante</p>
          </div>
        </div>
        <!-- Featured News: Avances Recientes -->
        <section class="mb-20">
          <div class="flex items-center gap-2 mb-8">
            <span class="material-symbols-outlined text-primary">update</span>
            <h2 class="text-2xl font-bold">Avances Recientes</h2>
          </div>
          <div
            class="group relative overflow-hidden rounded-xl bg-white dark:bg-white/5 shadow-sm border border-arena/20 flex flex-col md:flex-row"
          >
            <div class="md:w-1/2 h-64 md:h-auto overflow-hidden">
              <div
                class="w-full h-full bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
                data-alt="Community minga with people planting trees and cleaning land"
                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBpTlO6ZsrwHjGfbAP5p-VTuZZJues0wWuwQW4XG4IHx8zECDY6DjCVkUZ9w-h6RjTrda6SjduBZzb-6briNNmDOdmLgusmH5o02COxF-Z7PfWfsUwrHDNddVpVJNgzGY3MaetN0ocze5Z6qAsP1lO8Ycz6Wh8IvhE6i33lROBra6q_OkyuxZ9orNb4I-vdHhQ0RMx5A9MYJ4s2z51jIBEuLBW_KeV8di-trdYff2rsAAsAOYYK-KOvpo4uVeKmgiUTPpXtjTWM57Vc")'
              >
              </div>
            </div>
            <div class="md:w-1/2 p-8 flex flex-col justify-center">
              <span
                class="inline-block px-3 py-1 rounded-full bg-sage/10 text-sage text-xs font-bold uppercase tracking-wider mb-4"
                >Minga Comunitaria</span
              >
              <h3 class="text-2xl font-bold mb-3">Mingas en Chaupi San Luis</h3>
              <p
                class="text-slate-600 dark:text-slate-400 mb-6 leading-relaxed"
              >
                Preparando el terreno para nuestro futuro hogar: realizamos
                jornadas de limpieza integral, replanteo de linderos y una
                exitosa siembra de árboles nativos para proteger el entorno.
              </p>
              <div class="flex flex-wrap gap-4 items-center">
                <button
                  class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded-lg font-bold transition-all flex items-center gap-2"
                >
                  Ver detalles <span class="material-symbols-outlined text-sm"
                    >arrow_forward</span
                  >
                </button>
                <span class="text-slate-500 text-sm italic"
                  >Actualizado hace 2 días</span
                >
              </div>
            </div>
          </div>
        </section>
        <!-- Timeline: 4 años de trayectoria -->
        <section
          class="mb-20 bg-arena/10 dark:bg-white/5 rounded-3xl p-8 md:p-12"
        >
          <div class="flex items-center gap-2 mb-10">
            <span class="material-symbols-outlined text-primary">history</span>
            <h2 class="text-2xl font-bold">4 años de trayectoria</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
            <!-- Connecting Line (Desktop) -->
            <div
              class="hidden md:block absolute top-12 left-0 right-0 h-0.5 bg-arena/50 z-0"
            >
            </div>
            <div class="relative z-10 flex flex-col items-center text-center">
              <div
                class="size-12 rounded-full bg-primary text-white flex items-center justify-center mb-4 border-4 border-white dark:border-background-dark"
              >
                <span class="material-symbols-outlined">handshake</span>
              </div>
              <h4 class="font-bold text-lg mb-2">Fundación y Alianzas</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Inicio del sueño Renacer y establecimiento del soporte técnico
                inicial.
              </p>
            </div>
            <div class="relative z-10 flex flex-col items-center text-center">
              <div
                class="size-12 rounded-full bg-primary text-white flex items-center justify-center mb-4 border-4 border-white dark:border-background-dark"
              >
                <span class="material-symbols-outlined">landscape</span>
              </div>
              <h4 class="font-bold text-lg mb-2">Adquisición del Terreno</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Compra legal del terreno en Chaupi San Luis tras arduas
                gestiones colectivas.
              </p>
            </div>
            <div class="relative z-10 flex flex-col items-center text-center">
              <div
                class="size-12 rounded-full bg-primary text-white flex items-center justify-center mb-4 border-4 border-white dark:border-background-dark"
              >
                <span class="material-symbols-outlined"
                  >approval_delegation</span
                >
              </div>
              <h4 class="font-bold text-lg mb-2">Soporte MIDUVI</h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Reconocimiento y aval del MIDUVI para el desarrollo habitacional
                social.
              </p>
            </div>
          </div>
        </section>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
          <!-- Official Announcements -->
          <section>
            <div class="flex items-center gap-2 mb-6">
              <span class="material-symbols-outlined text-primary"
                >campaign</span
              >
              <h2 class="text-2xl font-bold">Comunicados Oficiales</h2>
            </div>
            <div class="space-y-4">
              <div
                class="p-4 bg-white dark:bg-white/5 rounded-xl border-l-4 border-primary shadow-sm"
              >
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold">Asamblea General Extraordinaria</h4>
                  <span
                    class="text-xs bg-arena text-slate-800 px-2 py-1 rounded"
                    >15 Oct</span
                  >
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  Convocatoria para todos los socios para definir etapas de
                  construcción.
                </p>
              </div>
              <div
                class="p-4 bg-white dark:bg-white/5 rounded-xl border-l-4 border-sage shadow-sm"
              >
                <div class="flex justify-between items-start mb-2">
                  <h4 class="font-bold">Nuevo Listado de Requisitos</h4>
                  <span
                    class="text-xs bg-arena text-slate-800 px-2 py-1 rounded"
                    >02 Oct</span
                  >
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  Actualización de documentos necesarios para la carpeta del
                  MIDUVI.
                </p>
              </div>
            </div>
          </section>
          <!-- Next Steps -->
          <section>
            <div class="flex items-center gap-2 mb-6">
              <span class="material-symbols-outlined text-primary">flag</span>
              <h2 class="text-2xl font-bold">Próximos Pasos</h2>
            </div>
            <div
              class="bg-primary/5 dark:bg-primary/10 rounded-2xl p-6 border border-primary/20"
            >
              <div class="flex items-center justify-between mb-4">
                <span class="text-lg font-semibold">Meta: 64 Socios</span>
                <span class="text-primary font-bold">85% Completado</span>
              </div>
              <div class="w-full bg-arena/30 rounded-full h-4 mb-6">
                <div class="bg-primary h-4 rounded-full" style="width: 85%">
                </div>
              </div>
              <p
                class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4"
              >
                Estamos a solo 10 cupos de completar el grupo oficial de 64
                socios para iniciar la fase 1 de urbanización. ¡Tu participación
                es clave!
              </p>
              <ul class="space-y-2">
                <li class="flex items-center gap-2 text-sm">
                  <span class="material-symbols-outlined text-sage text-lg"
                    >check_circle</span
                  >
                  Cierre de inscripciones: Diciembre 2024
                </li>
                <li class="flex items-center gap-2 text-sm">
                  <span class="material-symbols-outlined text-sage text-lg"
                    >check_circle</span
                  >
                  Apertura de calles internas
                </li>
              </ul>
            </div>
          </section>
        </div>
        <!-- Progress Gallery -->
        <section class="mb-20">
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary"
                >photo_library</span
              >
              <h2 class="text-2xl font-bold">Galería de Progreso</h2>
            </div>
            <button class="text-primary font-bold hover:underline"
              >Ver todas</button
            >
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div
              class="aspect-square bg-arena/20 rounded-xl overflow-hidden cursor-pointer"
            >
              <div
                class="w-full h-full bg-cover bg-center hover:scale-110 transition-transform"
                data-alt="Construction site ground preparation"
                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDo832E3UJWdGkm4xlYju-1fGHpucXUyk5mI_UHbUdKcqtrau6N3JJIviXeIP9_d7PJ5hpfwhtznYn2pwTU2yuIBmJUYR_ZpkmtM2arMqVCQtQWObSCJRrVYVb_yWU0aF9a6wN0gzkLoLnjrH0DEIpOyyngb_azx8JYDTKeSJdcXRlvJ4sL-Nj9ZD7IKzVsAIOBSXS9ThZcX_UigbReY8pgzowZW4Bem9eK1osmEY6J55v1psdr6gI8cM54q76k_4G0JXhe8BdKS9rR")'
              >
              </div>
            </div>
            <div
              class="aspect-square bg-arena/20 rounded-xl overflow-hidden cursor-pointer"
            >
              <div
                class="w-full h-full bg-cover bg-center hover:scale-110 transition-transform"
                data-alt="Official meeting of housing project partners"
                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDN0a1Toi59joIrSa3P3LRimcTu6tP09GA6XijOZHXMD2MNO51_KGJE-7e0FpKJ14wFew1ceZJ1inDoEMICHaIz7KkDhOFdySJxWBahgkxVkO9e88fCSAZC6ORJXFKXNPhXJBiG-iCKUVnH7P7o6rOu-qcTUw_4tP-6X5bdDLO99ZOZvMUqWJmtmwqBnY6yV77uhAFPW50XJc-T-CsDeQDfOijmLjIP4IUn25217uRVJ_ElIkpdrTlCwZAXzRlBlm3Y3BBxSMN0ZwD6")'
              >
              </div>
            </div>
            <div
              class="aspect-square bg-arena/20 rounded-xl overflow-hidden cursor-pointer"
            >
              <div
                class="w-full h-full bg-cover bg-center hover:scale-110 transition-transform"
                data-alt="Lush green land in Ambato region"
                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBcO5O_T1aMIOQtzk8eaolG-vjUED6WEkY9C5bx1bKLahf2fPeU2-SY9r7H0b2QfMbSgbqlPgofP9n4_b6JFlb4H0g34O7RPQOzazbzVCKuz69tdSKmzjNwSZhoaL_JGVD737TpcmRBTub1KlE8RRQYmZqbnSq5K4jh86JEYuuVNbaSqWKxgmTgACaCqBhYoqLOaaRy6UAz8RMmWKR14tkrJ0NXXGXTr7ipR_TmpjSk45YAajD5ZkpqJf3HrXlecrByAbV6uHsrrimn")'
              >
              </div>
            </div>
            <div
              class="aspect-square bg-arena/20 rounded-xl overflow-hidden cursor-pointer"
            >
              <div
                class="w-full h-full bg-cover bg-center hover:scale-110 transition-transform"
                data-alt="Architectural blueprints for housing"
                style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBRJpnwACJhCSu07LnophrgC3CUv2Bqp1i1Og-vzdikKbexNruATF3dRdiNodDa2SaGDpuCPq271Q_V3a472dRrDc8n3_f487U2dmVXH__dj_eply9owSBdx130m9gQDMVNFZEnZFf1Fy0s2SgpHmCCCI0VXRtsKvPC0QjdyRCnbH5u8H7kHYy1Ld_z2gf3u64OfVRU0Xn64Vsw2SqLgXA7MW4zuV9WaMwzzl81HZH1gW8tlq6Rz4sogjuPZ0BmggsjYStyVGQCohhs")'
              >
              </div>
            </div>
          </div>
        </section>
        <!-- Final CTA -->
        <section
          class="bg-primary rounded-3xl p-10 md:p-16 text-center text-white relative overflow-hidden"
        >
          <div
            class="absolute top-0 right-0 -mr-16 -mt-16 size-64 bg-white/10 rounded-full blur-3xl"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 -ml-16 -mb-16 size-64 bg-white/10 rounded-full blur-3xl"
          >
          </div>
          <h2 class="text-3xl md:text-5xl font-black mb-6 relative z-10">
            ¿Quieres ser parte del próximo avance?
          </h2>
          <p
            class="text-white/80 text-lg mb-10 max-w-2xl mx-auto relative z-10"
          >
            Aún quedan cupos disponibles para familias que deseen construir su
            futuro en un entorno comunitario y legal.
          </p>
          <div
            class="flex flex-col sm:flex-row justify-center gap-4 relative z-10"
          >
            <button
              class="bg-white text-primary px-8 py-4 rounded-xl font-bold text-lg hover:bg-arena transition-all shadow-lg"
              >Solicitar Información</button
            >
            <button
              class="bg-transparent border-2 border-white/50 hover:border-white text-white px-8 py-4 rounded-xl font-bold text-lg transition-all"
              >Ver Requisitos</button
            >
            <button
              class="bg-sage text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-sage/90 transition-all flex items-center justify-center gap-2"
            >
              <span class="material-symbols-outlined">calendar_month</span> Agendar
              Cita
            </button>
          </div>
        </section>
      </main>
      <!-- Footer -->
      <Footer />
    </div>
  </div>
</Layout>
