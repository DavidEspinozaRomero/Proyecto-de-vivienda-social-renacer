---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Contacto | Proyecto de Vivienda Social Renacer Ambato";
const description = "Contáctanos para recibir información sobre el proyecto de vivienda social Renacer en Ambato. Conoce requisitos, proceso y cómo ser socio."
---

<Layout title={title} description={description}>
  <!-- Top Navigation -->
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="py-12 lg:py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-900 dark:text-white mb-6 leading-tight"
        >
          Contacto - Proyecto de Vivienda Social <span class="text-primary"
            >Renacer</span
          > en Ambato
        </h1>
        <p
          class="text-lg md:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto"
        >
          Estamos aquí para ayudarte. Si no tienes propiedad, solicita
          información sobre terrenos disponibles en Ambato para empezar tu
          hogar.
        </p>
      </div>
    </section>
    <!-- Main Contact Grid -->
    <section class="max-w-7xl mx-auto px-4 pb-20">
      <div class="grid lg:grid-cols-12 gap-12">
        <!-- Left Column: Form and Checklist -->
        <div class="lg:col-span-7 space-y-12">
          <!-- Form Card -->
          <!-- <div
            class="bg-white dark:bg-slate-900 p-8 rounded-xl shadow-sm border border-beige-muted dark:border-slate-800"
          >
