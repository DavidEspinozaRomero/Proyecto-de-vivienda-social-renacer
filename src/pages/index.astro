---
import Layout from "../layouts/Layout.astro";
// import "../styles/global.css";
---

<Layout>
  <div class="text-center h-full place-content-center">
    <h1 class="text-2xl font-bold text-primary">
      Proyecto de Vivienda Social Renacer
    </h1>
    <p class="text-secondary">Sitio web en proceso de desarrollo</p>
    <button
      type="button"
      class="mt-10 inline-flex cursor-not-allowed items-center rounded-md bg-indigo-500 px-4 py-2 text-sm leading-6 font-semibold text-white transition duration-150 ease-in-out hover:bg-indigo-400"
      disabled=""
      ><svg
        class="mr-3 -ml-1 size-5 animate-spin text-white"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        ><circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle><path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path></svg
      >Processing…</button
    >
  </div>
  <!-- <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <header
      class="sticky top-0 z-50 w-full border-b border-neutral-beige/30 bg-background-light/80 backdrop-blur-md dark:bg-background-dark/80 px-4 md:px-20 lg:px-40 py-4 flex items-center justify-between"
    >
      <div class="flex items-center gap-2 text-primary">
        <span class="material-symbols-outlined text-3xl">home_pin</span>
        <h2 class="text-xl font-black tracking-tighter uppercase">RENACER</h2>
      </div>
      <nav class="hidden md:flex items-center gap-8">
        <a
          class="text-sm font-semibold hover:text-primary transition-colors"
          href="#inicio">Inicio</a
        >
        <a
          class="text-sm font-semibold hover:text-primary transition-colors"
          href="#proyecto">El Proyecto</a
        >
        <a
          class="text-sm font-semibold hover:text-primary transition-colors"
          href="#historia">Nuestra Historia</a
        >
        <a
          class="text-sm font-semibold hover:text-primary transition-colors"
          href="#requisitos">Requisitos</a
        >
        <a
          class="text-sm font-semibold hover:text-primary transition-colors"
          href="#contacto">Contacto</a
        >
      </nav>
      <div class="flex items-center gap-4">
        <button
          class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded-lg text-sm font-bold transition-all shadow-md"
        >
          Inscribirse
        </button>
      </div>
    </header>
    <main class="flex-1">
      <section
        class="px-4 md:px-20 lg:px-40 py-12 md:py-20 flex flex-col lg:flex-row items-center gap-12"
        id="inicio"
      >
        <div class="flex-1 flex flex-col gap-8">
          <div class="space-y-4">
            <h1
              class="text-4xl md:text-6xl font-black leading-[1.1] tracking-tight text-slate-900 dark:text-white"
            >
              Tu casa propia en Ambato <span class="text-primary"
                >empieza aquí</span
              >
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-300 max-w-xl">
              Proyecto de Vivienda Social en Ambato con 4 años de historia y
              respaldo de MIDUVI. Obtén tu primer terreno con Renacer si
              actualmente no posees vivienda.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <button
              class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-transform flex items-center gap-2"
            >
              Solicita información
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
            <button
              class="bg-white border-2 border-neutral-beige text-slate-800 px-8 py-4 rounded-xl font-bold text-lg hover:bg-neutral-beige/10 transition-colors"
            >
              Conoce los requisitos
            </button>
          </div>
          <div
            class="flex items-center gap-4 pt-4 border-t border-neutral-beige/30"
          >
            <div class="flex -space-x-3">
              <div
                class="w-10 h-10 rounded-full border-2 border-white bg-slate-200"
                data-alt="Avatar de socio feliz uno"
              >
              </div>
              <div
                class="w-10 h-10 rounded-full border-2 border-white bg-slate-300"
                data-alt="Avatar de socia comprometida dos"
              >
              </div>
              <div
                class="w-10 h-10 rounded-full border-2 border-white bg-slate-400"
                data-alt="Avatar de familia beneficiaria tres"
              >
              </div>
            </div>
            <p class="text-sm font-medium text-slate-500">
              Más de 60 familias ya son parte de este sueño.
            </p>
          </div>
        </div>
        <div class="flex-1 w-full">
          <div
            class="relative w-full aspect-4/3 rounded-3xl overflow-hidden shadow-2xl bg-neutral-beige/20 group"
            data-alt="Vista aérea de terrenos en Ambato con montañas"
          >
            <div
              class="absolute inset-0 bg-linear-to-t from-black/40 to-transparent"
            >
            </div>
            <div class="absolute bottom-6 left-6 text-white">
              <span
                class="bg-secondary/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider"
                >Proyecto Social</span
              >
              <p class="mt-2 text-xl font-bold">Sector Chaupi San Luis</p>
            </div>
          </div>
        </div>
      </section>
      <section
        class="bg-white dark:bg-background-dark/50 px-4 md:px-20 lg:px-40 py-20"
        id="proyecto"
      >
        <div class="max-w-4xl mx-auto text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-black mb-6">¿Qué es Renacer?</h2>
          <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed">
            Somos una iniciativa diseñada exclusivamente para personas y
            familias que actualmente arriendan en Ambato. Nuestra meta es
            consolidar a 64 socios fundadores para la entrega y legalización de
            su primer lote de terreno.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div
            class="p-8 rounded-2xl bg-background-light dark:bg-background-dark border border-neutral-beige/20 hover:shadow-xl transition-all"
          >
            <div
              class="w-14 h-14 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-6"
            >
              <span class="material-symbols-outlined text-3xl"
                >real_estate_agent</span
              >
            </div>
            <h3 class="text-xl font-bold mb-3">Vivienda Social</h3>
            <p class="text-slate-600 dark:text-slate-400">
              Respaldo total del MIDUVI enfocado en familias de escasos recursos
              sin vivienda propia.
            </p>
          </div>
          <div
            class="p-8 rounded-2xl bg-background-light dark:bg-background-dark border border-neutral-beige/20 hover:shadow-xl transition-all"
          >
            <div
              class="w-14 h-14 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center mb-6"
            >
              <span class="material-symbols-outlined text-3xl">groups</span>
            </div>
            <h3 class="text-xl font-bold mb-3">64 Socios</h3>
            <p class="text-slate-600 dark:text-slate-400">
              Buscamos familias comprometidas con el proyecto y el crecimiento
              comunitario.
            </p>
          </div>
          <div
            class="p-8 rounded-2xl bg-background-light dark:bg-background-dark border border-neutral-beige/20 hover:shadow-xl transition-all"
          >
            <div
              class="w-14 h-14 rounded-xl bg-neutral-beige/30 text-slate-700 dark:text-slate-300 flex items-center justify-center mb-6"
            >
              <span class="material-symbols-outlined text-3xl">location_on</span
              >
            </div>
            <h3 class="text-xl font-bold mb-3">Ubicación Estratégica</h3>
            <p
              class="text-slate-600 dark:text-slate-400"
              data-location="Ambato"
            >
              Terrenos ubicados en el próspero sector de Chaupi San Luis en
              Ambato.
            </p>
          </div>
        </div>
      </section>
      <section
        class="px-4 md:px-20 lg:px-40 py-20 bg-background-light dark:bg-background-dark"
        id="historia"
      >
        <div class="mb-16">
          <h2 class="text-3xl md:text-5xl font-black mb-4">
            4 Años Construyendo Futuro
          </h2>
          <p class="text-slate-600 dark:text-slate-400 max-w-2xl">
            Nuestra trayectoria es garantía de compromiso y transparencia.
          </p>
        </div>
        <div
          class="relative space-y-12 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-linear-to-b before:from-transparent before:via-neutral-beige before:to-transparent"
        >
          <div
            class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active"
          >
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-primary text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2"
            >
              <span class="material-symbols-outlined text-sm">event</span>
            </div>
            <div
              class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-2xl bg-white dark:bg-background-dark/80 shadow-sm border border-neutral-beige/20"
            >
              <div class="flex items-center justify-between space-x-2 mb-1">
                <div class="font-black text-primary text-xl">Año 1</div>
                <time class="font-medium text-slate-500 text-sm italic"
                  >Organización</time
                >
              </div>
              <div class="text-slate-600 dark:text-slate-300">
                Conformación de la directiva, registro legal y obtención del
                apoyo inicial de MIDUVI.
              </div>
            </div>
          </div>
          <div
            class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group"
          >
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-secondary text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2"
            >
              <span class="material-symbols-outlined text-sm">map</span>
            </div>
            <div
              class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-2xl bg-white dark:bg-background-dark/80 shadow-sm border border-neutral-beige/20"
            >
              <div class="flex items-center justify-between space-x-2 mb-1">
                <div class="font-black text-secondary text-xl">Año 2</div>
                <time class="font-medium text-slate-500 text-sm italic"
                  >Ubicación del Terreno</time
                >
              </div>
              <div class="text-slate-600 dark:text-slate-300">
                Identificación y negociación del predio ideal en el sector
                Chaupi San Luis – Ambato.
              </div>
            </div>
          </div>
          <div
            class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group"
          >
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-slate-800 text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2"
            >
              <span class="material-symbols-outlined text-sm">engineering</span>
            </div>
            <div
              class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-2xl bg-white dark:bg-background-dark/80 shadow-sm border border-neutral-beige/20"
            >
              <div class="flex items-center justify-between space-x-2 mb-1">
                <div
                  class="font-black text-slate-800 dark:text-slate-200 text-xl"
                >
                  Año 3
                </div>
                <time class="font-medium text-slate-500 text-sm italic"
                  >Gestión Técnica</time
                >
              </div>
              <div class="text-slate-600 dark:text-slate-300">
                Superación de desafíos municipales y permisos de fraccionamiento
                con perseverancia constante.
              </div>
            </div>
          </div>
          <div
            class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group"
          >
            <div
              class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-primary text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2"
            >
              <span class="material-symbols-outlined text-sm">verified</span>
            </div>
            <div
              class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-2xl bg-white dark:bg-background-dark/80 shadow-sm border border-neutral-beige/20"
            >
              <div class="flex items-center justify-between space-x-2 mb-1">
                <div class="font-black text-primary text-xl">Año 4</div>
                <time class="font-medium text-slate-500 text-sm italic"
                  >Consolidación</time
                >
              </div>
              <div class="text-slate-600 dark:text-slate-300">
                Compromiso firme con los 64 socios fundadores y preparación para
                la infraestructura final.
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="bg-secondary/5 px-4 md:px-20 lg:px-40 py-20">
        <div class="flex flex-col lg:flex-row gap-16 items-center">
          <div class="flex-1 space-y-8">
            <h2 class="text-3xl md:text-5xl font-black">
              Trabajo Comunitario y Mingas
            </h2>
            <p class="text-lg text-slate-600 dark:text-slate-400">
              En Renacer no solo compramos un terreno, construimos una
              comunidad. A través de nuestras jornadas colectivas, cuidamos el
              entorno que será nuestro hogar.
            </p>
            <div class="grid grid-cols-2 gap-6">
              <div class="flex gap-4">
                <span class="material-symbols-outlined text-secondary">eco</span
                >
                <div>
                  <h4 class="font-bold">Reforestación</h4>
                  <p class="text-sm text-slate-500">
                    Siembra de árboles nativos.
                  </p>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="material-symbols-outlined text-secondary"
                  >cleaning_services</span
                >
                <div>
                  <h4 class="font-bold">Mingas</h4>
                  <p class="text-sm text-slate-500">Limpieza y organización.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="flex-1 grid grid-cols-2 gap-4 w-full">
            <div
              class="aspect-square rounded-2xl bg-neutral-beige/40 overflow-hidden"
              data-alt="Vecinos trabajando juntos en minga de limpieza"
            >
            </div>
            <div
              class="aspect-3/4 rounded-2xl bg-neutral-beige/60 overflow-hidden translate-y-8"
              data-alt="Niños sembrando un árbol en el terreno"
            >
            </div>
            <div
              class="aspect-3/4 rounded-2xl bg-neutral-beige/20 overflow-hidden -translate-y-8"
              data-alt="Grupo de socios reunidos en el campo"
            >
            </div>
            <div
              class="aspect-square rounded-2xl bg-neutral-beige/50 overflow-hidden"
              data-alt="Herramientas de jardinería y manos trabajando la tierra"
            >
            </div>
          </div>
        </div>
      </section>
      <section
        class="px-4 md:px-20 lg:px-40 py-20 bg-white dark:bg-background-dark"
        id="requisitos"
      >
        <div class="grid lg:grid-cols-2 gap-16">
          <div
            class="bg-background-light dark:bg-background-dark/50 p-10 rounded-3xl border border-neutral-beige/20"
          >
            <h3 class="text-3xl font-black mb-8">¿Quiénes pueden postular?</h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full"
                  >check</span
                >
                <span class="text-lg font-medium"
                  >Personas que NO poseen vivienda propia en Ecuador.</span
                >
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full"
                  >check</span
                >
                <span class="text-lg font-medium"
                  >Residentes actuales en Ambato bajo modalidad de arriendo.</span
                >
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full"
                  >check</span
                >
                <span class="text-lg font-medium"
                  >Compromiso real con la organización social y comunitaria.</span
                >
              </li>
              <li class="flex items-start gap-4">
                <span
                  class="material-symbols-outlined text-secondary bg-secondary/10 p-1 rounded-full"
                  >check</span
                >
                <span class="text-lg font-medium"
                  >Deseo de construir su hogar definitivo en la ciudad de
                  Ambato.</span
                >
              </li>
            </ul>
            <button
              class="mt-10 w-full py-4 bg-slate-900 dark:bg-slate-700 text-white font-bold rounded-xl hover:bg-slate-800 transition-colors"
            >
              Ver requisitos para inscripción
            </button>
          </div>
          <div class="flex flex-col justify-center">
            <h3 class="text-3xl font-black mb-8">¿Por qué elegir Renacer?</h3>
            <div class="grid sm:grid-cols-2 gap-8">
              <div class="space-y-2">
                <h4 class="font-bold text-primary flex items-center gap-2">
                  <span class="material-symbols-outlined">history</span> Trayectoria
                </h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  4 años de gestión ininterrumpida y transparente.
                </p>
              </div>
              <div class="space-y-2">
                <h4 class="font-bold text-primary flex items-center gap-2">
                  <span class="material-symbols-outlined">handshake</span> MIDUVI
                </h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  Apoyo institucional del Ministerio de Vivienda.
                </p>
              </div>
              <div class="space-y-2">
                <h4 class="font-bold text-primary flex items-center gap-2">
                  <span class="material-symbols-outlined">diversity_3</span> Comunidad
                  Activa
                </h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  Una organización sólida basada en el respeto mutuo.
                </p>
              </div>
              <div class="space-y-2">
                <h4 class="font-bold text-primary flex items-center gap-2">
                  <span class="material-symbols-outlined">visibility</span> Transparencia
                </h4>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                  Cada avance es informado y consensuado con los socios.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="px-4 md:px-20 lg:px-40 py-24" id="contacto">
        <div
          class="bg-primary/10 rounded-[3rem] p-8 md:p-20 text-center relative overflow-hidden"
        >
          <div
            class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-64 h-64 bg-primary/20 rounded-full blur-3xl"
          >
          </div>
          <div
            class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-64 h-64 bg-secondary/20 rounded-full blur-3xl"
          >
          </div>
          <div class="relative z-10">
            <h2
              class="text-3xl md:text-6xl font-black text-slate-900 dark:text-white mb-8"
            >
              ¿Quieres tener tu propio terreno en Ambato?
            </h2>
            <p
              class="text-xl text-slate-700 dark:text-slate-300 mb-12 max-w-2xl mx-auto"
            >
              Únete a las últimas vacantes de nuestro proyecto y deja de pagar
              arriendo para siempre. Agenda tu reunión informativa hoy mismo.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <button
                class="bg-primary hover:bg-primary/90 text-white px-10 py-5 rounded-2xl font-black text-lg shadow-lg flex items-center justify-center gap-3"
              >
                <span class="material-symbols-outlined">calendar_month</span>
                Agenda tu reunión
              </button>
              <button
                class="bg-emerald-600 hover:bg-emerald-700 text-white px-10 py-5 rounded-2xl font-black text-lg shadow-lg flex items-center justify-center gap-3"
              >
                <span class="material-symbols-outlined">chat</span>
                Contáctanos por WhatsApp
              </button>
            </div>
          </div>
        </div>
      </section>
    </main>
    <footer class="bg-slate-900 text-white px-4 md:px-20 lg:px-40 py-16">
      <div class="grid md:grid-cols-4 gap-12 mb-12">
        <div class="col-span-2">
          <div class="flex items-center gap-2 text-primary mb-6">
            <span class="material-symbols-outlined text-3xl">home_pin</span>
            <h2 class="text-2xl font-black tracking-tighter uppercase">
              RENACER
            </h2>
          </div>
          <p class="text-slate-400 max-w-sm">
            Proyecto de vivienda social enfocado en brindar dignidad y
            estabilidad a las familias ambateñas. Juntos construimos el sueño de
            la casa propia.
          </p>
        </div>
        <div>
          <h4 class="font-bold mb-6">Navegación</h4>
          <ul class="space-y-4 text-slate-400">
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Sobre Nosotros</a>
            </li>
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Requisitos</a>
            </li>
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Procesos</a>
            </li>
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Sostenibilidad</a>
            </li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-6">Legal</h4>
          <ul class="space-y-4 text-slate-400">
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Términos y Condiciones</a>
            </li>
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >Política de Privacidad</a>
            </li>
            <li>
              <a class="hover:text-primary transition-colors" href="#"
                >MIDUVI Normativas</a>
            </li>
          </ul>
        </div>
      </div>
      <div
        class="pt-8 border-t border-slate-800 text-center text-slate-500 text-sm"
      >
        © 2024 RENACER Ambato. Proyecto de Interés Social. Todos los derechos
        reservados.
      </div>
    </footer>
  </div> -->
</Layout>
