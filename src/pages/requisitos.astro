---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const title = "Requisitos para obtener terreno en Ambato | Proyecto Renacer";
const description = "Consulta los requisitos para formar parte del proyecto de vivienda social Renacer en Ambato y acceder a tu primer terreno. Información clara y actualizada.";
---

<Layout title={title} description={description}>
  <!-- Navigation -->
  <Header />
  <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
    <main class="flex-1">
      <!-- Hero Section -->
      <section
        class="relative h-[400px] flex items-center justify-center overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-linear-to-r from-primary/40 to-secondary-sage/40 mix-blend-multiply z-10"
        >
        </div>
        <div
          class="absolute inset-0 bg-cover bg-center"
          data-alt="Viviendas sociales modernas en entorno natural"
          style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBrnK5MMrtNkWjXO9WgQB_kzlma-R65iM5TmLCPkyg3fioS2RpZ2Xumk7x6CJ3a6Zx1JBpFCU5UlyUhTcjLQZluQUCpeUsZ4eXDdZNKR-fS3uR4bgW6Jad0kwR0galUrXR0VRkg083LsaLh5qLvp78rMPm9wFEEK2w5gBvKB1EhiNsmE1XtIap8PaUUXE_sbPj_ae3T8HTjyOY2Wk3DGGhkmuhHMYNCN599oIHP_DLQ8tJJv8uZ3w8wz5KCRNTVCozayDgNkwJloMSS')"
        >
        </div>
        <div class="relative z-20 text-center px-6 max-w-4xl">
          <h1
            class="text-4xl md:text-5xl font-extrabold text-white leading-tight drop-shadow-lg"
          >
            Requisitos para acceder a un terreno en el Proyecto de Vivienda
            Social Renacer - Ambato
          </h1>
          <p class="mt-6 text-white/90 text-lg font-medium max-w-2xl mx-auto">
            Tu primer paso hacia un hogar digno comienza aquí. Conoce los
            lineamientos y documentación necesaria.
          </p>
        </div>
      </section>
      <div
        class="max-w-7xl mx-auto px-6 lg:px-20 py-16 grid grid-cols-1 lg:grid-cols-3 gap-12"
      >
        <!-- Left Column: Requirements -->
        <div class="lg:col-span-2 space-y-16">
          <!-- Who can apply? -->
          <section>
            <div class="flex items-center gap-3 mb-8">
              <span
                class="material-symbols-outlined text-secondary-sage text-3xl"
                >groups</span
              >
              <h2 class="text-3xl font-bold">¿Quiénes pueden postular?</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div
                class="flex items-start gap-4 p-5 bg-secondary-beige/20 rounded-xl border border-secondary-beige/30"
              >
                <span class="material-symbols-outlined text-primary mt-1"
                  >check_circle</span
                >
                <p class="text-base leading-relaxed">
                  No poseer vivienda propia en la jurisdicción del proyecto ni ser beneficiario
                  de otros programas de vivienda estatal.
                </p>
              </div>
              <div
                class="flex items-start gap-4 p-5 bg-secondary-beige/20 rounded-xl border border-secondary-beige/30"
              >
                <span class="material-symbols-outlined text-primary mt-1"
                  >check_circle</span
                >
                <p class="text-base leading-relaxed">
                  Vivir en la actualidad dentro del ámbito
                  territorial del proyecto.
                </p>
              </div>
              <div
                class="flex items-start gap-4 p-5 bg-secondary-beige/20 rounded-xl border border-secondary-beige/30"
              >
                <span class="material-symbols-outlined text-primary mt-1"
                  >check_circle</span
                >
                <p class="text-base leading-relaxed">
                  Deseo genuino de adquirir el primer terreno para vivienda
                  familiar en la ciudad de Ambato.
                </p>
              </div>
              <div
                class="flex items-start gap-4 p-5 bg-secondary-beige/20 rounded-xl border border-secondary-beige/30"
              >
                <span class="material-symbols-outlined text-primary mt-1"
                  >check_circle</span
                >
                <p class="text-base leading-relaxed">
                  Compromiso activo con la organización social y los procesos
                  comunitarios del proyecto.
                </p>
              </div>
            </div>
            <div
              class="mt-6 flex items-center gap-3 bg-secondary-sage/10 p-4 rounded-lg border-l-4 border-secondary-sage"
            >
              <span class="material-symbols-outlined text-secondary-sage"
                >info</span
              >
              <p class="text-sm font-medium italic">
                El proyecto cuenta con el aval, los lineamientos y apoyo del
                MIDUVI.
              </p>
            </div>
          </section>
          <!-- General Registration -->
          <section>
            <div class="flex items-center gap-3 mb-8">
              <span class="material-symbols-outlined text-primary text-3xl"
                >description</span
              >
              <h2 class="text-3xl font-bold">
                Requisitos Generales para Inscripción
              </h2>
            </div>
            <div
              class="bg-white dark:bg-slate-800/50 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden"
            >
              <ol class="divide-y divide-slate-100 dark:divide-slate-700">
                <li
                  class="p-6 flex items-center gap-6 group hover:bg-primary/5 transition-colors"
                >
                  <span
                    class="flex-none w-10 h-10 flex items-center justify-center bg-primary text-white rounded-full font-bold"
                    >01</span
                  >
                  <span class="text-lg">Ser mayor de 18 años de edad.</span>
                </li>
                <li
                  class="p-6 flex items-center gap-6 group hover:bg-primary/5 transition-colors"
                >
                  <span
                    class="flex-none w-10 h-10 flex items-center justify-center bg-primary text-white rounded-full font-bold"
                    >02</span
                  >
                  <span class="text-lg"
                    >Copia de Cédula de Identidad y Certificado de Votación
                    actualizado.</span
                  >
                </li>
                <li
                  class="p-6 flex items-center gap-6 group hover:bg-primary/5 transition-colors"
                >
                  <span
                    class="flex-none w-10 h-10 flex items-center justify-center bg-primary text-white rounded-full font-bold"
                    >03</span
                  >
                  <span class="text-lg"
                    >Una fotografía tamaño carné a color actualizada.</span
                  >
                </li>
                <li
                  class="p-6 flex items-center gap-6 group hover:bg-primary/5 transition-colors"
                >
                  <span
                    class="flex-none w-10 h-10 flex items-center justify-center bg-primary text-white rounded-full font-bold"
                    >04</span
                  >
                  <span class="text-lg"
                    >Certificado de Honorabilidad (personal o laboral).</span
                  >
                </li>
                <li
                  class="p-6 flex items-center gap-6 group hover:bg-primary/5 transition-colors"
                >
                  <span
                    class="flex-none w-10 h-10 flex items-center justify-center bg-primary text-white rounded-full font-bold"
                    >05</span
                  >
                  <span class="text-lg">
                    Certificado de Antecedentes Penales (actualizado).</span
                  >
                </li>
              </ol>
            </div>
          </section>
          <!-- Foreign Nationals -->
          <section
            class="bg-slate-900 text-white p-8 rounded-2xl shadow-xl relative overflow-hidden"
          >
            <div
              class="absolute top-0 right-0 w-32 h-32 bg-primary/20 rounded-full blur-3xl -mr-16 -mt-16"
            >
            </div>
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined text-primary text-3xl"
                >public</span
              >
              <h2 class="text-2xl font-bold">
                Requisitos para Personas Extranjeras
              </h2>
            </div>
            <ul class="space-y-4">
              <li class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary"
                  >id_card</span
                >
                <span class="text-slate-300"
                  >Pasaporte vigente o Cédula de Identidad para extranjeros.</span
                >
              </li>
              <li class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary"
                  >verified_user</span
                >
                <span class="text-slate-300"
                  >Pasado judicial apostillado del país de origen.</span
                >
              </li>
            </ul>
          </section>
          <!-- No Property Certificate -->
          <section
            class="border-2 border-dashed border-primary/30 p-8 rounded-2xl"
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-primary"
                >foundation</span
              >
              <h2 class="text-2xl font-bold">
                Certificación de No Poseer Vivienda
              </h2>
            </div>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-6">
              Este es el documento primordial para validar su postulación. Debe
              solicitar el <strong>
                Certificado de Bienes Raíces (Registro de la Propiedad)
              </strong> Que indique NO poseer bienes inmuebles en la jurisdicción.
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="p-4 bg-background-light dark:bg-slate-800 rounded-lg">
                <h4 class="font-bold text-sm uppercase text-primary mb-2">
                  Residencia
                </h4>
                <p class="text-sm">
                  Debe demostrar que vive dentro de la jurisdiccióndel proyecto mediante contrato de arriendo
                  o documento juramentado.
                </p>
              </div>
              <div class="p-4 bg-background-light dark:bg-slate-800 rounded-lg">
                <h4 class="font-bold text-sm uppercase text-primary mb-2">
                  Compromiso
                </h4>
                <p class="text-sm">
                  No debe pertenecer a ninguna otra organización de vivienda o
                  cooperativa habitacional similar.
                </p>
              </div>
            </div>
          </section>
        </div>
        <!-- Right Column: Sidebar / Process -->
        <div class="space-y-8">
          <div
            class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700"
          >
            <h3 class="text-2xl font-bold mb-8">¿Qué sigue después?</h3>
            <div class="space-y-8 relative">
              <div
                class="absolute left-4 top-2 bottom-2 w-0.5 bg-slate-100 dark:bg-slate-700"
              >
              </div>
              <div class="relative flex gap-4">
                <div
                  class="z-10 w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold ring-4 ring-white dark:ring-slate-800"
                >
                  1
                </div>
                <div>
                  <h4 class="font-bold text-lg">Revisión</h4>
                  <p class="text-sm text-slate-500">
                    Evaluación técnica de la documentación entregada.
                  </p>
                </div>
              </div>
              <div class="relative flex gap-4">
                <div
                  class="z-10 w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold ring-4 ring-white dark:ring-slate-800"
                >
                  2
                </div>
                <div>
                  <h4 class="font-bold text-lg">Validación</h4>
                  <p class="text-sm text-slate-500">
                    Validación por parte de la Asamblea General de Socios.
                  </p>
                </div>
              </div>
              <div class="relative flex gap-4">
                <div
                  class="z-10 w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-bold ring-4 ring-white dark:ring-slate-800"
                >
                  3
                </div>
                <div>
                  <h4 class="font-bold text-lg">Notificación</h4>
                  <p class="text-sm text-slate-500">
                    Comunicación oficial del estado de su postulación.
                  </p>
                </div>
              </div>
              <div class="relative flex gap-4">
                <div
                  class="z-10 w-8 h-8 rounded-full bg-secondary flex items-center justify-center text-white text-xs font-bold ring-4 ring-white dark:ring-slate-800"
                >
                  4
                </div>
                <div>
                  <h4 class="font-bold text-lg">Ingreso Formal</h4>
                  <p class="text-sm text-slate-500">
                    Firma de actas y bienvenida oficial al proyecto.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <!-- Sticky CTA Card -->
          <div
            class="bg-primary p-8 rounded-2xl text-white shadow-lg sticky top-32"
          >
            <h3 class="text-2xl font-bold mb-4">¿Necesitas ayuda?</h3>
            <p class="text-white/80 mb-8">
              Nuestros asesores están listos para guiarte en cada paso del
              proceso.
            </p>
            <div class="space-y-3">
              <!-- <button
                class="w-full bg-white text-primary font-bold py-3 rounded-xl flex items-center justify-center gap-2 hover:bg-slate-50 transition-colors"
              >
                <span class="material-symbols-outlined text-sm"
                  >calendar_month</span
                >
                Agenda una reunión
              </button> -->
              <a
                href="/contacto"
                class="w-full bg-white/10 text-white border border-white/20 font-bold py-3 rounded-xl flex items-center justify-center gap-2 hover:bg-white/20 transition-colors"
              >
                <span class="material-symbols-outlined text-sm"
                  >support_agent</span
                >
                Solicita asesoramiento
              </a>

              <a
                href="/como-ser-socio#FAQs"
                class="w-full bg-white/10 text-white border border-white/20 font-bold py-3 rounded-xl flex items-center justify-center gap-2 hover:bg-white/20 transition-colors"
              >
                <span class="material-symbols-outlined text-sm"
                  >help_outline</span
                >
                Consulta tus dudas
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
    <!-- Footer -->
    <Footer />
  </div>
</Layout>
