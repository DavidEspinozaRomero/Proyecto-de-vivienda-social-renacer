---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Proyecto de Vivienda Social Renacer - Ambato</title>

    <meta
      name="description"
      content="Proyecto de vivienda social Renacer en Ambato. Una oportunidad para personas que no tienen vivienda propia y desean obtener su primer terreno. Conoce requisitos y cómo ser socio."
    />

    <meta
      name="keywords"
      content="vivienda social Ambato, terrenos en Ambato, proyecto de vivienda Ambato, MIDUVI Ambato, obtener terreno Ambato, comité de vivienda Ambato"
    />

    <meta name="author" content="Proyecto de Vivienda Social Renacer" />

    <meta name="robots" content="index, follow" />

    <meta name="language" content="Spanish" />

    <meta name="geo.region" content="EC-T" />
    <meta name="geo.placename" content="Ambato" />

    <link rel="canonical" href="https://proyectoviviendarenacer.netlify.app/" />
    <!-- Open Graph -->
    <meta
      property="og:title"
      content="Proyecto de Vivienda Social Renacer | Terrenos en Ambato"
    />
    <meta
      property="og:description"
      content="¿No tienes casa propia en Ambato? Conoce el proyecto de vivienda social Renacer y descubre cómo obtener tu primer terreno. Información y requisitos disponibles."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://proyectoviviendarenacer.netlify.app"
    />
    <meta
      property="og:image"
      content="https://proyectoviviendarenacer.netlify.app/img/mockImg.webp"
    />

    <meta property="og:locale" content="es_EC" />
    <meta
      property="og:site_name"
      content="Proyecto de Vivienda Social Renacer"
    />
    <!-- Twitter Card (también usado por WhatsApp) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Obtén tu primer terreno en Ambato | Proyecto Renacer"
    />
    <meta
      name="twitter:description"
      content="Proyecto de vivienda social para personas que no tienen propiedad. Conoce requisitos y cómo ser socio del proyecto Renacer."
    />
    <meta
      name="twitter:image"
      content="https://proyectoviviendarenacer.netlify.app/img/mockImg.webp"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta property="og:locale" content="es_EC" />

    <meta name="theme-color" content="#2E7D32" />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background-light text-slate-900 font-display">
    <!-- Top Navigation -->
    <header
      class="sticky top-0 z-50 bg-background-light/95 backdrop-blur-md border-b border-primary/10"
    >
      <div
        class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
      >
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-3xl"
            >home_work</span
          >
          <h2 class="text-slate-900 text-xl font-black tracking-tight">
            RENACER
          </h2>
        </div>
        <nav class="hidden md:flex items-center gap-8">
          <a
            class="text-sm font-semibold hover:text-primary transition-colors"
            href="#inicio">Inicio</a
          >
          <a
            class="text-sm font-semibold hover:text-primary transition-colors"
            href="#nosotros">Nosotros</a
          >
          <a
            class="text-sm font-semibold hover:text-primary transition-colors"
            href="#requisitos">Requisitos</a
          >
          <a
            class="text-sm font-semibold hover:text-primary transition-colors"
            href="#comunidad">Comunidad</a
          >
        </nav>
        <button
          class="bg-primary text-white px-6 py-2.5 rounded-lg text-sm font-bold shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all"
        >
          Contactar
        </button>
      </div>
    </header>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-12 lg:py-24" id="inicio">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="flex flex-col gap-8 order-2 lg:order-1">
            <div
              class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full w-fit"
            >
              <span class="material-symbols-outlined text-sm">verified</span>
              <span class="text-xs font-bold uppercase tracking-wider"
                >Proyecto Institucional en Marcha</span
              >
            </div>
            <h1
              class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-slate-900 tracking-tight"
            >
              ¿No tienes casa propia en Ambato? Esta puede ser tu oportunidad de
              obtener tu <span class="text-primary">primer terreno</span>.
            </h1>
            <p class="text-lg text-slate-600 max-w-xl">
              Proyecto de Vivienda Social Renacer: Organizado – Comunitario –
              Con respaldo institucional. No somos una promesa, somos una
              realidad en construcción.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <button
                class="bg-primary text-white px-8 py-4 rounded-xl text-lg font-bold hover:scale-105 transition-transform shadow-xl shadow-primary/30"
              >
                Quiero Información Ahora
              </button>
              <div class="flex items-center gap-3 px-4">
                <div class="flex -space-x-3">
                  <div
                    class="w-10 h-10 rounded-full border-2 border-white bg-slate-200"
                    data-alt="Close up face of a smiling family member"
                  >
                  </div>
                  <div
                    class="w-10 h-10 rounded-full border-2 border-white bg-slate-300"
                    data-alt="Happy resident of the community project"
                  >
                  </div>
                  <div
                    class="w-10 h-10 rounded-full border-2 border-white bg-slate-400"
                    data-alt="Worker in the community land work"
                  >
                  </div>
                </div>
                <span
                  class="text-sm font-medium text-slate-500 underline decoration-primary/30 underline-offset-4"
                  >+48 socios activos</span
                >
              </div>
            </div>
          </div>
          <div class="relative order-1 lg:order-2">
            <div
              class="aspect-4/3 rounded-2xl bg-slate-200 overflow-hidden shadow-2xl ring-8 ring-white"
              data-alt="Beautiful landscape of land plots in Ambato area"
              style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDROebz3MbiNGAQt3JMx5CPoTD3-L2TTxztC5p03wHvrk7XiWakMuPkCmGXRdXXDOZ4ZHhSXiixhCeN2l-BA3Bo-w0rz0SKiwN8HXB-rCvd5jeIjkYUUgw-Pe5SCnbuQkMJVljds10E1s5YfN-k54pHlXQHFqp9MfpPP4G16sj3pgLvYIMWZCJAFPSbpbmggLTiDlgPiVYzaiX1mKp9L9jVCERX6Fw7iCnIRzZJVSyL905mo3TzCLJKFZbzi1G2JbjNqIp1k4rDMo6w'); background-size: cover;"
            >
            </div>
            <div
              class="absolute -bottom-6 -left-6 bg-white p-6 rounded-xl shadow-xl flex items-center gap-4 max-w-xs border border-primary/5"
            >
              <span class="material-symbols-outlined text-secondary text-4xl"
                >location_on</span
              >
              <div>
                <p
                  class="text-xs font-bold text-slate-400 uppercase tracking-widest"
                >
                  Ubicación
                </p>
                <p class="text-sm font-bold text-slate-900">
                  Sector Chaupi San Luis, Ambato
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- Problem Section -->
    <section class="bg-primary/5 py-20 border-y border-primary/10">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-6 text-slate-900">
          ¿Pagas arriendo cada mes y sientes que nunca avanzas?
        </h2>
        <p class="text-lg text-slate-700 leading-relaxed italic">
          "Muchas familias en Ambato viven esa realidad. Trabajan duro, pero el
          sueño de tener terreno propio parece cada vez más lejano. Renacer
          nació precisamente para cambiar eso."
        </p>
        <div class="mt-8 flex justify-center">
          <span
            class="material-symbols-outlined text-primary text-4xl opacity-20"
            >format_quote</span
          >
        </div>
      </div>
    </section>
    <!-- Solution Section -->
    <section class="py-24" id="nosotros">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2">
            <h2 class="text-3xl md:text-4xl font-black mb-8">
              Un proyecto creado para personas que no tienen vivienda propia
            </h2>
            <p class="text-lg text-slate-600 mb-10 leading-relaxed">
              El Comité de Vivienda Social Renacer es una organización formada
              hace 4 años con un objetivo claro: Ayudar a familias sin propiedad
              a acceder a su primer terreno en Ambato a través del esfuerzo
              conjunto y la gestión legal.
            </p>
            <div class="grid sm:grid-cols-3 gap-6">
              <div
                class="bg-white p-6 rounded-xl border border-primary/10 hover:shadow-lg transition-shadow"
              >
                <span
                  class="material-symbols-outlined text-primary mb-4 text-3xl"
                  >map</span
                >
                <h3 class="font-bold text-slate-900 mb-2">Ubicación</h3>
                <p class="text-sm text-slate-500">Sector Chaupi San Luis</p>
              </div>
              <div
                class="bg-white p-6 rounded-xl border border-primary/10 hover:shadow-lg transition-shadow"
              >
                <span
                  class="material-symbols-outlined text-primary mb-4 text-3xl"
                  >groups</span
                >
                <h3 class="font-bold text-slate-900 mb-2">Organización</h3>
                <p class="text-sm text-slate-500">Comunidad organizada</p>
              </div>
              <div
                class="bg-white p-6 rounded-xl border border-primary/10 hover:shadow-lg transition-shadow"
              >
                <span
                  class="material-symbols-outlined text-primary mb-4 text-3xl"
                  >history</span
                >
                <h3 class="font-bold text-slate-900 mb-2">Trayectoria</h3>
                <p class="text-sm text-slate-500">4 años de gestión sólida</p>
              </div>
            </div>
          </div>
          <div
            class="bg-secondary/10 p-8 rounded-2xl flex flex-col justify-center"
          >
            <h3 class="text-xl font-bold mb-6 text-secondary">
              Renacer no es una promesa. Es un proyecto en marcha.
            </h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-xl"
                  >check_circle</span
                >
                <span class="text-sm font-medium"
                  >Conformación legal y organizativa</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-xl"
                  >check_circle</span
                >
                <span class="text-sm font-medium"
                  >Respaldo institucional sólido</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-xl"
                  >check_circle</span
                >
                <span class="text-sm font-medium">Obtención del terreno</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-xl"
                  >check_circle</span
                >
                <span class="text-sm font-medium"
                  >Procesos técnicos y ordenanzas</span
                >
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-secondary text-xl"
                  >check_circle</span
                >
                <span class="text-sm font-medium"
                  >Inicio de mingas comunitarias</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <!-- Community Section -->
    <section class="bg-slate-900 text-white py-24 relative" id="comunidad">
      <div
        class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center"
      >
        <div class="flex flex-col gap-8">
          <h2 class="text-4xl font-black">
            Mucho más que un terreno: Una Comunidad
          </h2>
          <p class="text-lg text-slate-400">
            Aquí no solo se adquiere un terreno. Se forma parte de una comunidad
            que participa en asambleas, trabaja en mingas, construye en conjunto
            y se apoya mutuamente.
          </p>
          <div class="bg-white/5 p-8 rounded-2xl border border-white/10">
            <div class="flex items-center justify-between mb-4">
              <span
                class="text-sm font-bold uppercase tracking-widest text-primary"
                >Estado del Proyecto</span
              >
              <span class="text-2xl font-black"
                >48 <span class="text-slate-500 font-normal">de 64 socios</span
                ></span
              >
            </div>
            <div class="w-full bg-white/10 h-4 rounded-full overflow-hidden">
              <div class="bg-primary h-full rounded-full" style="width: 75%">
              </div>
            </div>
            <p class="mt-4 text-xs text-slate-500 text-center">
              ¡Solo quedan 16 cupos disponibles para nuevas familias!
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div
            class="aspect-square rounded-xl bg-slate-800"
            data-alt="Community meeting showing organized group of people"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCHh7--MB-TvgPpy23-og5W8I3fniCvc6rxV0yJyTRDsIWMoIb5oDaOiadGRI0pElQSpWVMXW1B8ZUqNshh6YjTmX5eGV_3cRppx_QdjH73hncctPwzAun-ZP3yWv8ZatGBoyAI_d73Jdx4Jdz7jf2bRXszFqh44OuxVfCZb5sAaJ5sCgYMRSwOWAvORdStr5wN7vtxL5T2HtWIYS73vW1zWcSKnYpMUSIghUNbEf2NUZk_YqhsmmRoWfnYQ1aZKGghV2Hnrx17mS0G'); background-size: cover;"
          >
          </div>
          <div
            class="aspect-square rounded-xl bg-slate-800 translate-y-8"
            data-alt="Community working together on construction or land clearing"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDxFtv0eXw7XuuHZAmDn3S6mVQRsZzc8MC6w967JGXdn7kY00eStM40MiezwEWo_V6ogzLjiIVGE6C_jRcCqL-H7ONi6ZF9T9_WhBY85Y3x_vT_n9AyjwsJekxt8pM-VSXzUKIikgpT50F1KV6OfOJxEVU4-hW6Juoo45kd2_rXKaVy-Noi0ZSxT9axC2i8xzvtUzzlAom8aNgw0f--VCXva3vcFvSgh9D9HZ62FIepZ0GvGSo_qnDQPpqQmfCF0B0KymGA3zThkalS'); background-size: cover;"
          >
          </div>
          <div
            class="aspect-square rounded-xl bg-slate-800"
            data-alt="People working on outdoor community project"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBixQoFSkV0V5ByBMy3CN1k9PD-i0KysnNTWnxjJOkSVEjOF5TsuypVWgk4_4pG2VSB2uVqMgEngjFIj5VMKzvSd_GelYm4BrJNw_N55sDpEkhnlNfoQqT7WbSKgSQZvFuPtGTRwiNg0mh-_MwAa2naH_GWCAD2diWq0HHMR0w6EwqctUArkujabk7x3dDVSZiPvbp-vX9in8T-JARfg-4eRAtEFwVOn2JDB6Ek5FEXb30RJa7oErEzBcWlxKR9sIy7raYmbdlM_tO0'); background-size: cover;"
          >
          </div>
          <div
            class="aspect-square rounded-xl bg-slate-800 translate-y-8"
            data-alt="Close up of hands working together in construction"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBEJTuOL-YYePHN1VE5erMbrJOSJEK-UwSSkJXLDClrK31uw97-H2imAc9zoPW_YhxCmm77LwPG7JfxFPT2ReCw6jOKTQ8XgTJxpqOpHGJPm6xygTGt11zS92pIiyUE6aV_aJRxEwJFxevhJO9lCIHKXtrkJglTp-hMneOVER2391jvV1KUdMWkEbDI1rXVtGg4sDZ6BRuxQEsUX0nC3t-_0aWyFor7oXTUUBU2ycagIFfDA1HyYmxTBnqBJ09ZSysnB55lyipLfJNy'); background-size: cover;"
          >
          </div>
        </div>
      </div>
    </section>
    <!-- Qualification & Urgency -->
    <section class="py-24" id="requisitos">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-4xl font-black mb-6">¿Quién puede postular?</h2>
          <p class="text-lg text-slate-500">
            Buscamos familias comprometidas con el crecimiento comunitario.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <div
            class="p-8 bg-white border border-primary/10 rounded-2xl text-center flex flex-col items-center"
          >
            <span class="material-symbols-outlined text-primary text-5xl mb-6"
              >house</span
            >
            <h3 class="text-xl font-bold mb-4">No poseen vivienda</h3>
            <p class="text-slate-500">
              Personas que no tengan ninguna propiedad a su nombre en el sistema
              nacional.
            </p>
          </div>
          <div
            class="p-8 bg-white border border-primary/10 rounded-2xl text-center flex flex-col items-center"
          >
            <span class="material-symbols-outlined text-primary text-5xl mb-6"
              >payments</span
            >
            <h3 class="text-xl font-bold mb-4">Son arrendatarios</h3>
            <p class="text-slate-500">
              Familias que actualmente viven en calidad de arriendo y quieren
              dejar de pagar por algo que no es suyo.
            </p>
          </div>
          <div
            class="p-8 bg-white border border-primary/10 rounded-2xl text-center flex flex-col items-center"
          >
            <span class="material-symbols-outlined text-primary text-5xl mb-6"
              >construction</span
            >
            <h3 class="text-xl font-bold mb-4">Deseo de construir</h3>
            <p class="text-slate-500">
              Personas con el sueño real de construir su primer hogar propio en
              Ambato.
            </p>
          </div>
        </div>
        <div
          class="mt-20 bg-primary rounded-3xl p-8 md:p-12 text-center text-white relative overflow-hidden"
        >
          <div class="relative z-10">
            <h2 class="text-3xl font-black mb-6">¡Los cupos son limitados!</h2>
            <p class="text-xl mb-10 max-w-2xl mx-auto text-white/90">
              El proyecto tiene una meta organizativa de 64 socios. Ya somos 48
              familias. Si estás interesado, este es el momento de informarte
              antes de completar el grupo.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-6">
              <button
                class="bg-white text-primary px-8 py-4 rounded-xl text-lg font-bold shadow-2xl shadow-black/20 hover:bg-slate-50 transition-colors flex items-center justify-center gap-2"
              >
                <span class="material-symbols-outlined">chat</span>
                Escribir por WhatsApp
              </button>
              <button
                class="bg-slate-900 text-white px-8 py-4 rounded-xl text-lg font-bold shadow-2xl shadow-black/20 hover:bg-slate-800 transition-colors"
              >
                Quiero saber los requisitos
              </button>
            </div>
          </div>
          <div class="absolute inset-0 opacity-10 pointer-events-none">
            <svg
              class="w-full h-full"
              preserveAspectRatio="none"
              viewBox="0 0 100 100"
            >
              <path
                d="M0 100 C 20 0 50 0 100 100"
                fill="none"
                stroke="white"
                stroke-width="0.5"></path>
              <path
                d="M0 80 C 30 10 70 10 100 80"
                fill="none"
                stroke="white"
                stroke-width="0.5"></path>
            </svg>
          </div>
        </div>
      </div>
    </section>
    <!-- Footer -->
    <footer class="bg-slate-100 py-16 border-t border-slate-200">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-12 mb-16">
          <div class="col-span-1 md:col-span-2">
            <div class="flex items-center gap-2 mb-6">
              <span class="material-symbols-outlined text-primary text-3xl"
                >home_work</span
              >
              <h2
                class="text-slate-900 text-xl font-black tracking-tight uppercase"
              >
                RENACER
              </h2>
            </div>
            <p class="text-lg text-slate-600 italic font-medium">
              "Renacer no vende sueños. Construye oportunidades reales."
            </p>
          </div>
          <div>
            <h4
              class="font-bold mb-6 uppercase text-xs tracking-widest text-slate-400"
            >
              Institucional
            </h4>
            <ul class="space-y-4 text-sm font-semibold text-slate-600">
              <li>Organización social establecida</li>
              <li>Reuniones y asambleas formales</li>
              <li>Trabajo comunitario activo</li>
              <li>Proyecto con respaldo institucional</li>
            </ul>
          </div>
          <div>
            <h4
              class="font-bold mb-6 uppercase text-xs tracking-widest text-slate-400"
            >
              Contacto
            </h4>
            <p class="text-sm font-semibold text-slate-600 mb-2">
              Ambato, Ecuador
            </p>
            <p class="text-sm font-semibold text-slate-600">
              Sector Chaupi San Luis
            </p>
            <div class="mt-6 flex gap-4">
              <span
                class="material-symbols-outlined text-primary cursor-pointer"
                >social_leaderboard</span
              >
              <span
                class="material-symbols-outlined text-primary cursor-pointer"
                >mail</span
              >
              <span
                class="material-symbols-outlined text-primary cursor-pointer"
                >call</span
              >
            </div>
          </div>
        </div>
        <div
          class="pt-8 border-t border-slate-200 text-center text-xs text-slate-400 font-bold tracking-widest uppercase"
        >
          © 2024 Proyecto Renacer Ambato. Todos los derechos reservados.
        </div>
      </div>
    </footer>
  </body>
</html>
